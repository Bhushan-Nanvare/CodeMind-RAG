# GitHub Authentication (optional — increases rate limits)
GITHUB_TOKEN=your-github-token-here

# Ingestion Limits
MAX_REPO_SIZE=500
MAX_FILES=5000
TEMP_DIR=./temp

# Logging
LOG_LEVEL=INFO

# API
BACKEND_URL=http://localhost:8000
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile


# Qdrant Cloud (Vector Database)
# Sign up at: https://cloud.qdrant.io (free tier)
# Without these, the system falls back to in-memory Qdrant (no persistence)
QDRANT_URL=https://your-cluster.region.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION_NAME=codemind-codebase
VECTOR_DIMENSION=384



# HuggingFace (Embeddings)
# Sign up at: https://huggingface.co — token from /settings/tokens
# Without this key, the system uses local deterministic mock embeddings
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=16
EMBEDDING_CACHE_SIZE=10000
